# Postgres connection string (Railway Postgres plugin gives you one)
DATABASE_URL=postgres://user:password@host:5432/metamorfoza

# Used to sign the admin session cookie. Generate one with:
#   openssl rand -hex 32
SESSION_SECRET=change-me-to-a-64-char-hex-string-with-at-least-32-characters

# Shared password for the admin panel
ADMIN_PASSWORD=pick-a-strong-password

# Where uploaded PDFs are written. On Railway, set this to your mounted volume path, e.g. /data/uploads
UPLOAD_DIR=./data/uploads
